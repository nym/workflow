# LLM
ANTHROPIC_API_KEY=sk-ant-...

# Model assignments (orchestrator-worker pattern)
# Roles are separated by invocation to prevent self-review.
ORCHESTRATOR_MODEL=claude-opus-4-7        # high-stakes decisions, planning, long-horizon tasks
IMPLEMENTER_MODEL=claude-sonnet-4-6       # code generation, edits
ADVERSARY_MODEL=claude-sonnet-4-6         # adversarial review (separate invocation)
VERIFIER_MODEL=claude-haiku-4-5-20251001  # cheap checks: lint, format, syntax

# Opus 4.7 effort levels (xhigh is new in 4.7, sits between high and max)
# Per-call selection driven by task stakes; see BEST_PRACTICES.md.
EFFORT_LOW=low              # routine reads, formatting
EFFORT_MEDIUM=medium        # standard code generation
EFFORT_HIGH=high            # multi-file refactors, test design
EFFORT_XHIGH=xhigh          # architecture, security, irreversible actions
DEFAULT_EFFORT=medium

# Opus 4.7 task budgets (new — caps spend per agent task)
# On approach to ceiling, agent must checkpoint to SCRATCHPAD.md and escalate.
TASK_BUDGET_TOKENS=50000

# Governance / circuit breaker
MAX_AGENT_ITERATIONS=5
HUMAN_REVIEW_THRESHOLD=high              # low | medium | high
REQUIRE_ADVERSARIAL_REVIEW=true
LOG_FILE=log.json
SCRATCHPAD_FILE=SCRATCHPAD.md            # Opus 4.7 file-system memory
LOG_LEVEL=info

# Testing
COVERAGE_FLOOR=80
